# Copy this file to .env and fill in your values.
# All variables have safe defaults for local Docker development.

# PostgreSQL
DB_NAME=playto_payout
DB_USER=postgres
DB_PASSWORD=postgres

# Django
SECRET_KEY=local-dev-secret-change-in-prod

# Redis (used by Celery broker + result backend)
# REDIS_URL is set automatically inside docker-compose; override only for manual setup.
# REDIS_URL=redis://localhost:6379/0
